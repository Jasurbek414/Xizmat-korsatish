# Ushbu faylni ".env" nomi bilan nusxalab, haqiqiy qiymatlarni kiriting.
# ".env" fayli .gitignore orqali git'ga tushmaydi - maxfiy qiymatlarni faqat shu yerda saqlang.

# --- Ma'lumotlar bazasi ---
DB_USER=postgres
DB_PASSWORD=postgres

# --- Backend xavfsizligi ---
# JWT tokenlarni imzolash uchun kalit. Kamida 32 belgidan iborat tasodifiy qiymat bo'lishi shart.
# Generatsiya qilish: openssl rand -base64 48
JWT_SECRET=

# Ruxsat etilgan originlar, vergul bilan ajratilgan. Wildcard qo'llab-quvvatlanadi
# (masalan https://*.ecos.uz - har bir kompaniya o'z subdomeniga ega bo'lgani uchun).
# Brauzer ko'p hollarda "same-origin" so'rovlarda ham Origin header yuboradi, shu sabab
# haqiqiy production domenlaringizni ham shu yerga qo'shish shart - aks holda barcha
# so'rovlar (hatto /auth/login ham) 403 bilan rad etiladi.
CORS_ALLOWED_ORIGINS=http://localhost:3005,http://localhost:5173,https://*.ecos.uz

# --- Cloudflare Tunnel ---
# Cloudflare Zero Trust panelidan olinadigan tunnel tokeni.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Telefoniya (FreeSWITCH) ---
# ESL (Event Socket Library) paroli - backend va freeswitch xizmatlarida
# BIR XIL bo'lishi SHART (aks holda ESL autentifikatsiyasi muvaffaqiyatsiz
# tugaydi). Standart FreeSWITCH parolidan ("ClueCon") farqli, o'zingiz
# generatsiya qilgan qiymat bilan almashtiring: openssl rand -hex 24
FREESWITCH_ESL_PASSWORD=

# SIP hisob parollarini bazada shifrlash uchun kalit (SipPasswordConverter).
# Generatsiya qilish: openssl rand -base64 32
SIP_CREDENTIALS_KEY=

# --- Firebase Cloud Messaging (mobil push bildirishnoma) ---
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Faylni backend-java/firebase-service-account.json sifatida saqlab, docker-compose.yml'dagi
# tegishli "volumes" qatorlarini faollashtiring, keyin shu yerga konteyner ichidagi yo'lni yozing:
FIREBASE_SERVICE_ACCOUNT_PATH=
